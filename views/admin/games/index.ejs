<%- include('../../partials/admin_wrapper_start') %>

<div class="container-fluid px-4">
  <h1 class="mt-4">Games Management</h1>
  <ol class="breadcrumb mb-4">
    <li class="breadcrumb-item active">Manage Games</li>
  </ol>

  <div class="mb-3">
    <a href="/admin/games/new" class="btn btn-primary"><i class="fas fa-plus me-2"></i>New Game</a>
  </div>

  <div class="card mb-4 shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
      <span><i class="fas fa-gamepad me-2"></i>Games List</span>
      <span class="badge bg-secondary"><%= games.length %> items</span>
    </div>

    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
          <thead class="table-dark">
            <tr class="text-center">
              <th>Name</th>
              <th>Genres</th>
              <th>Rating</th>
              <th>Created</th>
              <th style="width: 140px">Actions</th>
            </tr>
          </thead>

          <tbody>
            <% games.forEach(g => { %>
              <tr>
                <td class="fw-semibold"><a href="/games/<%= g._id %>" class="text-decoration-none"><%= g.name %></a></td>
                <td>
                  <% if (g.genres && g.genres.length) { %>
                    <% g.genres.forEach(gg => { %>
                      <span class="badge bg-info text-dark"><%= gg.name %></span>
                    <% }) %>
                  <% } else { %>
                    <span class="text-muted">—</span>
                  <% } %>
                </td>
                <td class="text-center">
                  <% if (g.rating != null) { %>
                    <span class="badge bg-warning text-dark">⭐ <%= g.rating %></span>
                  <% } else { %>
                    <span class="text-muted">N/A</span>
                  <% } %>
                </td>
                <td class="text-center"><small class="text-muted"><%= g.createdAt.toLocaleString() %></small></td>
                <td class="text-center">
                  <a href="/admin/games/<%= g._id %>/edit" class="btn btn-sm btn-secondary me-1">Edit</a>
                  <form action="/admin/games/<%= g._id %>?_method=DELETE" method="post" style="display:inline-block;">
                    <button class="btn btn-sm btn-danger" onclick="return confirm('Delete this game?');">Delete</button>
                  </form>
                </td>
              </tr>
            <% }) %>

            <% if (games.length === 0) { %>
              <tr>
                <td colspan="5" class="text-center text-muted">No games found.</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('../../partials/admin_wrapper_end') %>