<%- include('../partials/header') %>

<div class="container py-4">
  <div class="row">
    
    <!-- LEFT CONTENT -->
    <div class="col-lg-8">

      <!-- IMAGE + RATING -->
      <% if (game.image) { %>
        <div class="position-relative mb-4">
          <% const gameImageSrc = (typeof game.image === 'string' && game.image.startsWith('http')) ? game.image : ('/uploads/' + game.image); %>
          <img src="<%= gameImageSrc %>"
            class="img-fluid rounded shadow-sm w-100"
            style="max-height:420px;object-fit:cover;"
            onerror="this.onerror=null;this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'800\' height=\'420\'><rect width=\'100%\' height=\'100%\' fill=\'%23eeeeee\'/><text x=\'50%\' y=\'50%\' dominant-baseline=\'middle\' text-anchor=\'middle\' fill=\'%23999\' font-family=\'Arial\' font-size=\'24\'>No+image</text></svg>'" />

          <% 
            const displayRating = (typeof game.globalRating !== 'undefined' && game.globalRating !== null) ? game.globalRating : game.rating;
            const ratingClass = displayRating > 8 ? 'bg-success' : (displayRating >=5 ? 'bg-warning text-dark' : 'bg-danger');
          %>

          <div class="position-absolute top-0 end-0 m-3 px-3 py-2 rounded <%= ratingClass %> text-white fw-bold">
            ⭐ <%= (typeof displayRating !== 'undefined' ? displayRating : 'N/A') %>
          </div>
        </div>
      <% } %>

      <!-- TITLE -->
      <h1 class="fw-bold"><%= game.name %></h1>

      <!-- META INFO -->
      <div class="mb-3 text-muted">
        <strong>Genres:</strong>
        <% if (game.genres && game.genres.length) { %>
          <%= game.genres.map(g => g.name).join(', ') %>
        <% } else { %> N/A <% } %>
      </div>

      <div class="row mb-3">
        <div class="col-md-6"><strong>Publisher:</strong> <%= game.publisher || 'N/A' %></div>
        <div class="col-md-6"><strong>Release:</strong> <%= game.releaseDate ? game.releaseDate.toDateString() : 'N/A' %></div>
        <div class="col-md-6"><strong>Price:</strong> <%= game.price || 'N/A' %></div>
        <div class="col-md-6"><strong>Sold:</strong> <%= game.sold || 'N/A' %></div>
      </div>
              <%= (game.rating ?? 'N/A') %> / 10
            </div>
            <% if (game.userRatingCount) { %>
              <small class="text-muted"><%= game.userRatingCount %> votes</small>
            <% } %>
          </div>

        </div>
      </div>

      <!-- CONTENT -->
      <div class="mb-4" style="white-space:pre-wrap;">
        <%= game.content %>
      </div>

      <hr />

      <!-- COMMENTS -->
      <h4 class="mb-3">Comments</h4>

      <% if (comments.length === 0) { %>
        <div class="text-muted">No comments yet.</div>
      <% } %>

      <% comments.forEach(c => { %>
        <div class="card mb-3 shadow-sm" id="comment-<%= c._id %>">
          <div class="card-body">

            <!-- HEADER -->
            <div class="d-flex justify-content-between">
              <div>
                <strong><%= c.user.username %></strong>
                <small class="text-muted"> • <%= c.createdAt.toLocaleString() %></small>
                <div>
                  <span class="badge bg-primary">
                    ⭐ <%= (typeof c.rating !== 'undefined') ? c.rating : 'N/A' %>/10
                  </span>
                </div>
              </div>

              <!-- ACTION -->
              <div>
                <% if (currentUser && (currentUser.id === (c.user._id ? c.user._id.toString() : c.user) || currentUser.role === 'admin')) { %>
                  <button class="btn btn-sm btn-outline-secondary js-edit-comment" data-id="<%= c._id %>">Edit</button>
                  <form action="/comments/<%= c._id %>?_method=DELETE" method="post" style="display:inline">
                    <button class="btn btn-sm btn-outline-danger">Delete</button>
                  </form>
                <% } %>
              </div>
            </div>

            <% /* comment images removed */ %>

            <!-- LIKE / DISLIKE -->
            <div class="mt-3 d-flex gap-2">
              <button class="btn btn-sm btn-outline-primary js-like-btn" data-id="<%= c._id %>">
                👍 <span class="like-count"><%= c.likedBy?.length || 0 %></span>
              </button>

              <button class="btn btn-sm btn-outline-secondary js-dislike-btn" data-id="<%= c._id %>">
                👎 <span class="dislike-count"><%= c.dislikedBy?.length || 0 %></span>
              </button>
            </div>

            <!-- EDIT FORM -->
            <form action="/comments/<%= c._id %>?_method=PUT"
                  method="post"
                  class="mt-3 d-none edit-form"
                  id="edit-form-<%= c._id %>">

              <textarea name="content" class="form-control mb-2" rows="3"><%= c.content %></textarea>

              <select name="rating" class="form-select mb-2">
                <% for (let i = 0; i <= 10; i++) { %>
                  <option value="<%= i %>" <%= (c.rating === i) ? 'selected' : '' %>><%= i %></option>
                <% } %>
              </select>

              <button class="btn btn-primary btn-sm">Save</button>
              <button type="button" class="btn btn-secondary btn-sm js-cancel-edit" data-id="<%= c._id %>">Cancel</button>
            </form>

          </div>
        </div>
      <% }) %>

      <!-- ADD COMMENT -->
      <div class="card mt-4 shadow-sm">
        <div class="card-body">

            <% if (currentUser) { %>
            <form action="/comments" method="post">
              <input type="hidden" name="gameId" value="<%= game._id %>">

              <textarea name="content" class="form-control mb-3" rows="3" placeholder="Write your comment..." required></textarea>

              <select name="rating" class="form-select mb-3">
                <% for (let i = 0; i <= 10; i++) { %>
                  <option value="<%= i %>"><%= i %></option>
                <% } %>
              </select>

              <button class="btn btn-primary">Post Comment</button>
            </form>
          <% } else { %>
            <div class="text-muted">
              <a href="/auth/login">Login</a> to comment.
            </div>
          <% } %>

        </div>
      </div>

    </div>
  </div>
</div>

<%- include('../partials/footer') %>
<script src="/js/comments.js"></script>
<!-- comment image preview removed -->