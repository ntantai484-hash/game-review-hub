<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin - Game Review Hub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
      <div class="container">
        <a class="navbar-brand" href="/">Game Review Hub</a>
        <div class="collapse navbar-collapse">
          <ul class="navbar-nav ms-auto">
            <% if (!currentUser) { %>
              <li class="nav-item"><a class="nav-link" href="/auth/login">Login</a></li>
            <% } else { %>
              <li class="nav-item"><a class="nav-link" href="/">Back to site</a></li>
              <li class="nav-item"><form action="/auth/logout" method="post"><button class="btn btn-link nav-link">Logout</button></form></li>
            <% } %>
          </ul>
        </div>
      </div>
    </nav>

    <div class="container-fluid admin-container">
      <div class="admin-sidebar-wrap">
        <div class="admin-sidebar admin-panel">
          <%- include('../partials/sidebar') %>
        </div>
      </div>
      <div class="admin-content">
        <div class="admin-panel">
          <% if (success && success.length) { %>
            <div class="alert alert-success"><%= success[0] %></div>
          <% } %>
          <% if (error && error.length) { %>
            <div class="alert alert-danger"><%= error[0] %></div>
          <% } %>
